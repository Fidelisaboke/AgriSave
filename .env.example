# Environment Type
DOCKER_ENV=false  # Set to true for Docker development
RENDER=false      # Set to true for Render deployment

# Django Core Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*.onrender.com

# Database Configuration (For Docker development)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=agrisave_db
DB_USER=agrisave_user
DB_PASSWORD=agrisave_pass123
DB_HOST=postgres # Use 'postgres' for Docker, 'localhost' for local, or use DATABASE_URL for Render
DB_PORT=5432

# Database URL (For Render/Production - overrides individual DB settings)
# Get this from your Render PostgreSQL service
DATABASE_URL=

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.onrender.com

# Redis/Celery Configuration
# For Docker development
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# For Render production (get from your Render Redis service)
# REDIS_URL=rediss://red-abc123:password@oregon-redis.render.com:6379
# CELERY_BROKER_URL=rediss://red-abc123:password@oregon-redis.render.com:6379
# CELERY_RESULT_BACKEND=rediss://red-abc123:password@oregon-redis.render.com:6379
